# Rename this file to ".env" and put your real API key here.
# Keep .env out of git to avoid leaking secrets.
OPENAI_API_KEY=your_key_here
# Optional proxy for OpenAI access (e.g. Clash)
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1
# Gemini (Google AI) key and model
GEMINI_API_KEY=your_key_here
# AI provider: "gemini" or "openai"
AI_PROVIDER=gemini
# Optional: set to a valid model name returned by /api/gemini-models
# Example (verify in your account): models/gemini-1.5-flash-001
GEMINI_MODEL=models/gemini-1.5-flash-001
